line 1: "=================================================
line 2: " File: plugin/undotree.vim
line 3: " Description: Manage your undo history in a graph.
line 4: " Author: Ming Bai <mbbill@gmail.com>
line 5: " License: BSD
line 6: 
line 7: " Avoid installing twice.
line 8: if exists('g:loaded_undotree')
line 9:     finish
line 10: endif
line 11: let g:loaded_undotree = 0
line 12: 
line 13: " At least version 7.3 with 005 patch is needed for undo branches.
line 14: " Refer to https://github.com/mbbill/undotree/issues/4 for details.
line 15: " Thanks kien
line 16: if v:version < 703
line 17:     command! -nargs=0 -bar UndotreeToggle :echoerr "undotree.vim needs Vim version >= 7.3"
line 18:     finish
line 19: endif
line 20: if (v:version == 703 && !has("patch005"))
line 21:     command! -nargs=0 -bar UndotreeToggle :echoerr "undotree.vim needs vim7.3 with patch005 applied."
line 22:     finish
line 23: endif
line 24: let g:loaded_undotree = 1   " Signal plugin availability with a value of 1.
line 25: 
line 26: "=================================================
line 27: "Options:
line 28: 
line 29: " Window layout
line 30: " style 1
line 31: " +----------+------------------------+
line 32: " |          |                        |
line 33: " |          |                        |
line 34: " | undotree |                        |
line 35: " |          |                        |
line 36: " |          |                        |
line 37: " +----------+                        |
line 38: " |          |                        |
line 39: " |   diff   |                        |
line 40: " |          |                        |
line 41: " +----------+------------------------+
line 42: " Style 2
line 43: " +----------+------------------------+
line 44: " |          |                        |
line 45: " |          |                        |
line 46: " | undotree |                        |
line 47: " |          |                        |
line 48: " |          |                        |
line 49: " +----------+------------------------+
line 50: " |                                   |
line 51: " |   diff                            |
line 52: " |                                   |
line 53: " +-----------------------------------+
line 54: " Style 3
line 55: " +------------------------+----------+
line 56: " |                        |          |
line 57: " |                        |          |
line 58: " |                        | undotree |
line 59: " |                        |          |
line 60: " |                        |          |
line 61: " |                        +----------+
line 62: " |                        |          |
line 63: " |                        |   diff   |
line 64: " |                        |          |
line 65: " +------------------------+----------+
line 66: " Style 4
line 67: " +-----------------------++----------+
line 68: " |                        |          |
line 69: " |                        |          |
line 70: " |                        | undotree |
line 71: " |                        |          |
line 72: " |                        |          |
line 73: " +------------------------+----------+
line 74: " |                                   |
line 75: " |                            diff   |
line 76: " |                                   |
line 77: " +-----------------------------------+
line 78: if !exists('g:undotree_WindowLayout')
line 79:     let g:undotree_WindowLayout = 1
line 80: endif
line 81: 
line 82: " e.g. using 'd' instead of 'days' to save some space.
line 83: if !exists('g:undotree_ShortIndicators')
line 84:     let g:undotree_ShortIndicators = 0
line 85: endif
line 86: 
line 87: " undotree window width
line 88: if !exists('g:undotree_SplitWidth')
line 89:     if g:undotree_ShortIndicators == 1
line 90:         let g:undotree_SplitWidth = 24
line 91:     else
line 92:         let g:undotree_SplitWidth = 30
line 93:     endif
line 94: endif
line 95: 
line 96: " diff window height
line 97: if !exists('g:undotree_DiffpanelHeight')
line 98:     let g:undotree_DiffpanelHeight = 10
line 99: endif
line 100: 
line 101: " auto open diff window
line 102: if !exists('g:undotree_DiffAutoOpen')
line 103:     let g:undotree_DiffAutoOpen = 1
line 104: endif
line 105: 
line 106: " if set, let undotree window get focus after being opened, otherwise
line 107: " focus will stay in current window.
line 108: if !exists('g:undotree_SetFocusWhenToggle')
line 109:     let g:undotree_SetFocusWhenToggle = 0
line 110: endif
line 111: 
line 112: " tree node shape.
line 113: if !exists('g:undotree_TreeNodeShape')
line 114:     let g:undotree_TreeNodeShape = '*'
line 115: endif
line 116: 
line 117: " tree vertical shape.
line 118: if !exists('g:undotree_TreeVertShape')
line 119:     let g:undotree_TreeVertShape = '|'
line 120: endif
line 121: 
line 122: " tree split shape.
line 123: if !exists('g:undotree_TreeSplitShape')
line 124:     let g:undotree_TreeSplitShape = '/'
line 125: endif
line 126: 
line 127: " tree return shape.
line 128: if !exists('g:undotree_TreeReturnShape')
line 129:     let g:undotree_TreeReturnShape = '\'
line 130: endif
line 131: 
line 132: if !exists('g:undotree_DiffCommand')
line 133:     let g:undotree_DiffCommand = "diff"
line 134: endif
line 135: 
line 136: " relative timestamp
line 137: if !exists('g:undotree_RelativeTimestamp')
line 138:     let g:undotree_RelativeTimestamp = 1
line 139: endif
line 140: 
line 141: " Highlight changed text
line 142: if !exists('g:undotree_HighlightChangedText')
line 143:     let g:undotree_HighlightChangedText = 1
line 144: endif
line 145: 
line 146: " Highlight changed text using signs in the gutter
line 147: if !exists('g:undotree_HighlightChangedWithSign')
line 148:     let g:undotree_HighlightChangedWithSign = 1
line 149: endif
line 150: 
line 151: " Highlight linked syntax type.
line 152: " You may chose your favorite through ":hi" command
line 153: if !exists('g:undotree_HighlightSyntaxAdd')
line 154:     let g:undotree_HighlightSyntaxAdd = "DiffAdd"
line 155: endif
line 156: if !exists('g:undotree_HighlightSyntaxChange')
line 157:     let g:undotree_HighlightSyntaxChange = "DiffChange"
line 158: endif
line 159: if !exists('g:undotree_HighlightSyntaxDel')
line 160:     let g:undotree_HighlightSyntaxDel = "DiffDelete"
line 161: endif
line 162: 
line 163: " Signs to display in the gutter where the file has been modified
line 164: if !exists('g:undotree_SignAdded')
line 165:     let g:undotree_SignAdded = "++"
line 166: endif
line 167: if !exists('g:undotree_SignChanged')
line 168:     let g:undotree_SignChanged = "~~"
line 169: endif
line 170: if !exists('g:undotree_SignDeleted')
line 171:     let g:undotree_SignDeleted = "--"
line 172: endif
line 173: if !exists('g:undotree_SignDeletedEnd')
line 174:     let g:undotree_SignDeletedEnd = "-v"
line 175: endif
line 176: 
line 177: " Deprecates the old style configuration.
line 178: if exists('g:undotree_SplitLocation')
line 179:     echo "g:undotree_SplitLocation is deprecated, please use g:undotree_WindowLayout instead."
line 181: endif
line 182: 
line 183: " Show help line
line 184: if !exists('g:undotree_HelpLine')
line 185:     let g:undotree_HelpLine = 1
line 186: endif
line 187: 
line 188: " Show cursorline
line 189: if !exists('g:undotree_CursorLine')
line 190:     let g:undotree_CursorLine = 1
line 191: endif
line 192: 
line 193: " Set statusline
line 194: if !exists('g:undotree_StatusLine')
line 195:     let g:undotree_StatusLine = 1
line 196: endif
line 197: 
line 198: " Ignored filetypes
line 199: if !exists('g:undotree_DisabledFiletypes')
line 200:     let g:undotree_DisabledFiletypes = []
line 201: endif
line 202: 
line 203: " Ignored buftypes
line 204: if !exists('g:undotree_DisabledBuftypes')
line 205:     let g:undotree_DisabledBuftypes = ['terminal', 'prompt', 'quickfix', 'nofile']
line 206: endif
line 207: 
line 208: " Define the default persistence undo directory if not defined in vim/nvim
line 209: " startup script.
line 210: if !exists('g:undotree_UndoDir')
line 211:     let s:undoDir = &undodir
line 212:     let s:subdir = has('nvim') ? 'nvim' : 'vim'
line 213:     if s:undoDir == "."
line 214:         let s:undoDir = $HOME . '/.local/state/' . s:subdir . '/undo/'
line 215:     endif
line 216:     let g:undotree_UndoDir = s:undoDir
line 217: endif
line 218: 
line 219: augroup undotreeDetectPersistenceUndo
line 220:     au!
line 221:     au BufReadPost * call undotree#UndotreePersistUndo(0)
line 222: augroup END
line 223: 
line 224: "=================================================
line 225: " User commands.
line 226: command! -nargs=0 -bar UndotreeToggle      :call undotree#UndotreeToggle()
line 227: command! -nargs=0 -bar UndotreeHide        :call undotree#UndotreeHide()
line 228: command! -nargs=0 -bar UndotreeShow        :call undotree#UndotreeShow()
line 229: command! -nargs=0 -bar UndotreeFocus       :call undotree#UndotreeFocus()
line 230: command! -nargs=0 -bar UndotreePersistUndo :call undotree#UndotreePersistUndo(1)
